---
interface Props {
	siteName: string;
	variant?: 'transparent' | 'solid';
	textColor?: 'white' | 'black' | 'adaptive';
}

const { siteName, variant = 'transparent', textColor = 'adaptive' } = Astro.props;

const headerClasses = variant === 'solid' 
	? 'fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-black/80 backdrop-blur-sm'
	: 'fixed top-0 left-0 right-0 z-50';

const logoClasses = textColor === 'white' 
	? 'text-white text-lg sm:text-xl tracking-wide'
	: textColor === 'black'
	? 'text-black text-lg sm:text-xl tracking-wide'
	: 'text-white dark:text-white text-lg sm:text-xl md:text-black tracking-wide';

const desktopLinkClasses = textColor === 'white'
	? 'text-white hover:opacity-70 transition-opacity tracking-wide'
	: textColor === 'black'
	? 'text-black hover:opacity-70 transition-opacity tracking-wide'
	: 'text-black dark:text-white hover:opacity-70 transition-opacity tracking-wide';

const mobileLinkClasses = textColor === 'white'
	? 'text-white hover:opacity-70 transition-opacity tracking-wide'
	: textColor === 'black'
	? 'text-black hover:opacity-70 transition-opacity tracking-wide'
	: 'text-white hover:opacity-70 transition-opacity tracking-wide';

const mobileButtonClasses = textColor === 'white'
	? 'md:hidden text-white'
	: textColor === 'black'
	? 'md:hidden text-black'
	: 'md:hidden text-white';
---

<header class={headerClasses}>
	<nav class="mx-auto px-4 sm:px-6 py-4 sm:py-8">
		<div class="flex justify-between items-center">
			<a href="/" class={logoClasses}>{siteName}</a>

			<!-- Desktop Navigation -->
			<div class="hidden md:flex space-x-8">
				<a href="/collections" class={desktopLinkClasses}>Collections</a>
				<a href="/asciiRenderer" class={desktopLinkClasses}>ASCII Renderer</a>
				<a href="/vfx" class={desktopLinkClasses}>VFX</a>
				<a href="/contact" class={desktopLinkClasses}>Contact</a>
			</div>

			<!-- Mobile Menu Button -->
			<button id="mobile-menu-button" class={mobileButtonClasses}>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
				</svg>
			</button>
		</div>

		<!-- Mobile Navigation Menu -->
		<div id="mobile-menu" class="hidden md:hidden mt-4 pb-4">
			<div class="flex flex-col space-y-4 pt-4">
				<a href="/collections" class={mobileLinkClasses}>Collections</a>
				<a href="/asciiRenderer" class={mobileLinkClasses}>ASCII Renderer</a>
				<a href="/vfx" class={mobileLinkClasses}>VFX</a>
				<a href="/contact" class={mobileLinkClasses}>Contact</a>
			</div>
		</div>
	</nav>
</header>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const mobileMenuButton = document.getElementById('mobile-menu-button');
		const mobileMenu = document.getElementById('mobile-menu');

		if (mobileMenuButton && mobileMenu) {
			mobileMenuButton.addEventListener('click', function() {
				mobileMenu.classList.toggle('hidden');
			});
		}
	});
</script>
