---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { websiteSettings as websiteSettingsFromData } from '../data/collections';
import Header from '../components/Header.astro';

const websiteSettings = websiteSettingsFromData;

---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href={websiteSettings.favIconUrl} />
		<title>{websiteSettings.websiteName} - Contact</title>
		
		<!-- Preload critical images -->
		<link rel="preload" as="image" href="/assets/contact.jpg" />
	</head>
	<body class="bg-white dark:bg-black">
	<Header siteName={websiteSettings.name} variant="transparent" textColor="adaptive" />

		<!-- Main Content -->
		<main class="min-h-screen flex flex-col lg:flex-row dark:bg-black relative">
			<!-- Mobile Background Image -->
			<div class="lg:hidden fixed inset-0 z-0">
				<Image
					src="/assets/contact.jpg"
					alt="Contact Background"
					class="h-full w-full object-cover"
					width={1920}
					height={2880}
					format="webp"
					quality={100}
					loading="eager"
				/>
				<div class="absolute inset-0 bg-black/40"></div>
			</div>

			<!-- Desktop Left Side - Image -->
			<div class="hidden lg:block lg:w-1/2 h-screen">
				<Image
					src="/assets/contact.jpg"
					alt="Contact Background"
					class="h-full w-full object-cover"
					width={1920}
					height={1080}
					format="webp"
					quality={100}
					loading="eager"
				/>
			</div>

			<!-- Contact Info -->
			<div class="w-full lg:w-1/2 h-screen flex items-center justify-center lg:justify-start relative z-10">
				<div class="px-4 sm:px-8 lg:px-16 max-w-md lg:max-w-xl text-center lg:text-left">
					<h1 class="title-font text-2xl sm:text-4xl mb-8 sm:mb-12 text-white lg:text-black lg:dark:text-white">Contact</h1>
					
					<div class="space-y-6 sm:space-y-8">
						<div>
							<h2 class="text-xs sm:text-sm uppercase tracking-widest mb-2 text-gray-300 lg:text-gray-600 lg:dark:text-gray-400">Email</h2>
							<a href="mailto:{websiteSettings.contactInformation.email}" class="text-white lg:text-black lg:dark:text-white hover:opacity-70 transition-opacity text-sm sm:text-base">
								{websiteSettings.contactInformation.email}
							</a>
						</div>

						<div>
							<h2 class="text-xs sm:text-sm uppercase tracking-widest mb-2 text-gray-300 lg:text-gray-600 lg:dark:text-gray-400">Social</h2>
							<a href="https://www.instagram.com/aleixdiazzz/" class="text-white lg:text-black lg:dark:text-white hover:opacity-70 transition-opacity text-sm sm:text-base">
								@aleixdiazzz
							</a> <br/>
							<a href="https://www.instagram.com/benzzzodiazepina/" class="text-white lg:text-black lg:dark:text-white hover:opacity-70 transition-opacity text-sm sm:text-base">
								@benzzzodiazepina
							</a>
						</div>

						<!-- PHONE
						<div>
							<h2 class="text-xs sm:text-sm uppercase tracking-widest mb-2 text-gray-300 lg:text-gray-600 lg:dark:text-gray-400">Phone</h2>
							<a href="tel:{websiteSettings.contactInformation.phoneNumber}" class="text-white lg:text-black lg:dark:text-white hover:opacity-70 transition-opacity text-sm sm:text-base">
								{websiteSettings.contactInformation.phoneNumber}
							</a>
						</div>-->

						<!-- LOCATION
						<div>
							<h2 class="text-xs sm:text-sm uppercase tracking-widest mb-2 text-gray-300 lg:text-gray-600 lg:dark:text-gray-400">Location</h2>
							<p class="text-white lg:text-black lg:dark:text-white text-sm sm:text-base">
								{websiteSettings.contactInformation.address.number} {websiteSettings.contactInformation.address.street}<br />
								{websiteSettings.contactInformation.address.city} {websiteSettings.contactInformation.address.postalCode}<br />
								{websiteSettings.contactInformation.address.country}
							</p>
						</div>-->
					</div>
				</div>
			</div>
		</main>

	</body>
</html> 