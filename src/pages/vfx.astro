---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { websiteSettings as websiteSettingsFromData } from '../data/collections';
import Header from '../components/Header.astro';
import headacheVisuals from '../assets/videoImage/headacheVisuals.png';
import particlesVisuals from '../assets/videoImage/particles.jpg';
import flockVisuals from '../assets/videoImage/flocks.png';

const websiteSettings = websiteSettingsFromData
---

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={websiteSettings.favIconUrl} />
    <title>VFX - {websiteSettings.name}</title>
</head>
<body class="bg-white dark:bg-black">
<Header siteName={websiteSettings.name} variant="solid" textColor="adaptive" />

<!-- Main Content -->
<main class="pt-16 pb-16 sm:pb-32 px-4 sm:px-6" style="margin-bottom: 50px;">
    <div class="mx-auto">

        <a href="/walking-around" class="w-full md:w-1/2 max-w-[1000px] flex flex-col justify-center items-center text-left mx-auto mt-14 md:mt-28">
            <Image
                    src={headacheVisuals}
                    alt={""}
                    class="w-full h-[500px] object-cover"
                    width={1000}
                    height={500}
                    format="webp"
                    quality={100}
                    loading="lazy"
            />
            <div class="text-black dark:text-white w-full text-xs sm:text-sm mt-2">
                <p>Walking Aroung</p>
                <p>Aleix Díaz Llabrés</p>
                <p class="text-gray-600 dark:text-gray-400">Truisms 4 Dummies - Headache</p>
            </div>
        </a>

        <a href="/dancer" class="w-full md:w-1/2 max-w-[1000px] flex flex-col justify-center items-center text-left mx-auto mt-14 md:mt-28">
            <Image
                    src={particlesVisuals}
                    alt={""}
                    class="w-full h-[500px] object-cover"
                    width={1000}
                    height={500}
                    format="webp"
                    quality={100}
                    loading="lazy"
            />
            <div class="text-black dark:text-white w-full text-xs sm:text-sm mt-2">
                <p>Dancer</p>
                <p>Aleix Díaz Llabrés</p>
                <p class="text-gray-600 dark:text-gray-400">Into The Doldrums - Now Always Fades</p>
            </div>
        </a>

        <a href="/flocks" class="w-full md:w-1/2 max-w-[1000px] flex flex-col justify-center items-center text-left mx-auto mt-14 md:mt-28">
            <Image
                    src={flockVisuals}
                    alt={""}
                    class="w-full h-[500px] object-cover"
                    width={1000}
                    height={500}
                    format="webp"
                    quality={100}
                    loading="lazy"
            />
            <div class="text-black dark:text-white w-full text-xs sm:text-sm mt-2">
                <p>Flocks</p>
                <p>Aleix Díaz Llabrés</p>
                <p class="text-gray-600 dark:text-gray-400">Inta - Aloka</p>
            </div>
        </a>

    </div>


</main>

<!-- Mobile Menu JavaScript -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const mobileMenuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');

        if (mobileMenuButton && mobileMenu) {
            mobileMenuButton.addEventListener('click', function() {
                mobileMenu.classList.toggle('hidden');
            });
        }
    });
</script>
</body>
</html>