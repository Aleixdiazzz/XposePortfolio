---
import '../styles/global.css';
import { websiteSettings as websiteSettingsFromData } from '../data/collections';
import Header from '../components/Header.astro';

const websiteSettings = websiteSettingsFromData
---

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={websiteSettings.favIconUrl} />
    <title>ASCII Renderer - {websiteSettings.name}</title>
</head>
<body class="bg-white dark:bg-black">
<Header siteName={websiteSettings.name} variant="solid" textColor="adaptive" />

<main class="pt-20 sm:pt-32 px-4 sm:px-6">
    <div>
        <canvas id="canvas"></canvas>
        <video id="webcam" autoplay playsinline muted></video>

        <!-- ASCII Output and Controls Container -->
        <div id="content-wrapper" style="display:none">
            <pre id="ascii" class="dark:text-white text-black"></pre>
        </div>

        <!-- Start Camera Button -->
        <div id="button-container" class="flex justify-center items-center min-h-[60vh]">
            <button id="start-camera">
                <span class="px-6 py-3 bg-black dark:bg-white text-white dark:text-black hover:opacity-70 transition-opacity tracking-wide text-sm sm:text-base">
                    Start Camera
                </span>
            </button>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const canvas = document.getElementById("canvas") as HTMLCanvasElement;
        const video = document.getElementById("webcam") as HTMLVideoElement;
        const asciiElement = document.getElementById("ascii") as HTMLPreElement;
        const buttonContainer = document.getElementById("button-container") as HTMLDivElement;
        const contentWrapper = document.getElementById("content-wrapper") as HTMLDivElement;
        const startButton = document.getElementById("start-camera") as HTMLButtonElement;

        if (!canvas || !video || !asciiElement) return;

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const charset = "@#S%?*+;:,. ";
        const RESOLUTION = 180;
        const CONTRAST = 2.0;

        function isPortraitMode(): boolean {
            return window.innerHeight > window.innerWidth && video.videoWidth > video.videoHeight;
        }

        function generateAscii(): string {
            if (isPortraitMode()) {
                // Landscape video → portrait ASCII via 90° CW canvas rotation
                const scale = RESOLUTION / video.videoHeight;
                const w = RESOLUTION;
                const h = Math.floor(video.videoWidth * scale);
                canvas.width = w;
                canvas.height = h;
                ctx.save();
                ctx.translate(w, 0);
                ctx.rotate(Math.PI / 2);
                ctx.drawImage(video, 0, 0, h, w);
                ctx.restore();
            } else {
                const scale = RESOLUTION / video.videoWidth;
                canvas.width = RESOLUTION;
                canvas.height = Math.floor(video.videoHeight * scale);
                ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            }

            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const pixels = imageData.data;
            let ascii = "";

            for (let y = 0; y < canvas.height; y += 2) {
                for (let x = 0; x < canvas.width; x++) {
                    const index = (y * canvas.width + x) * 4;
                    const r = pixels[index];
                    const g = pixels[index + 1];
                    const b = pixels[index + 2];

                    let gray = 0.299 * r + 0.587 * g + 0.114 * b;
                    gray = ((gray / 255 - 0.5) * CONTRAST + 0.5) * 255;
                    gray = Math.max(0, Math.min(255, gray));

                    const charIndex = charset.length - 1 - Math.floor((gray / 255) * (charset.length - 1));
                    ascii += charset[charIndex];
                }
                ascii += "\n";
            }

            return ascii;
        }

        function loop() {
            if (video.videoWidth > 0 && video.videoHeight > 0) {
                asciiElement.textContent = generateAscii();
            }
            requestAnimationFrame(loop);
        }

        function updateFontSize() {
            let fontSize: number;
            if (isPortraitMode()) {
                const asciiRows = Math.floor(video.videoWidth * (RESOLUTION / video.videoHeight) / 2);
                const byWidth = contentWrapper.clientWidth / (RESOLUTION * 0.55);
                const byHeight = asciiRows > 0 ? contentWrapper.clientHeight / asciiRows : byWidth;
                fontSize = Math.max(byWidth, byHeight);
            } else {
                const asciiRows = video.videoHeight > 0
                    ? Math.floor((video.videoHeight / video.videoWidth) * RESOLUTION / 2)
                    : Math.floor(RESOLUTION * 0.3);
                const byWidth = contentWrapper.clientWidth / (RESOLUTION * 0.55);
                const byHeight = contentWrapper.clientHeight / asciiRows;
                fontSize = Math.min(byWidth, byHeight);
            }
            asciiElement.style.fontSize = `${fontSize}px`;
            asciiElement.style.lineHeight = `${fontSize}px`;
        }

        startButton.addEventListener("click", async () => {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: false });
                video.srcObject = stream;
                video.addEventListener('loadedmetadata', updateFontSize);
                await video.play();

                buttonContainer.style.display = "none";
                contentWrapper.style.display = "flex";
                updateFontSize();
                loop();
            } catch (err) {
                const label = startButton.querySelector("span");
                if (label) label.textContent = "Camera access denied";
            }
        });

        window.addEventListener("resize", updateFontSize);

    });
</script>

<style>
    #content-wrapper {
        justify-content: center;
        align-items: center;
        height: calc(100vh - 8rem);
    }

    #ascii {
        font-family: monospace;
        overflow: hidden;
        white-space: pre;
        letter-spacing: 0;
        display: block;
    }

    :global(.dark) #ascii {
        color: #fff;
    }

    #canvas, #webcam {
        display: none;
    }

    @media (max-width: 640px) {
        #content-wrapper {
            height: calc(100vh - 5rem);
            height: calc(100dvh - 5rem);
            overflow: hidden;
        }
    }
</style>
</body>
</html>
